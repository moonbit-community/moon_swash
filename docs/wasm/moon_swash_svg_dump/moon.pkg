import {
  "peter-jerry-ye/wasi",
  "peter-jerry-ye/wasi/stdio",
  "peter-jerry-ye/wasi/fs",
  "moonbitlang/core/encoding/utf8" @utf8,
  "Milky2018/moon_zeno" @zeno,
  "Milky2018/moon_swash" @swash,
  "Milky2018/moon_swash/shape" @shape,
  "Milky2018/moon_swash/scale" @scale,
}

supported_targets = "wasm"

options(
  "is-main": true,
  link: { "wasm": { "export-memory-name": "memory" } },
)
